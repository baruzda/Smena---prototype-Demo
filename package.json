{
  "name": "x5-shift-prototype",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "vite build --base=./",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "validate:card-rules": "node scripts/validate-card-rules-cross-registry.mjs && node scripts/validate-card-rules.mjs",
    "check:card-rules-generated": "node scripts/validate-card-rules.mjs --check-generated",
    "test:card-rules": "node scripts/test-card-rules-validator.mjs",
    "test:card-rules-validator": "node --test tests/card-rules-validator/validator.spec.mjs",
    "test:ci": "npm run validate:card-rules && npm run check:card-rules-generated && npm run test:card-rules && npm run test:card-rules-validator && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "6.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "ajv": "^8.17.1"
  }
}
