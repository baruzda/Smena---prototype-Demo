        "section": "pending_confirmation",
        "appliedRules": [
          "RULE-MYTASKS-002"
        ]
      },
      "executionStatus": "declarative"
    },
    {
      "id": "SCN-MYTASKS-003",
      "name": "Услуга завершена",
      "given": {
        "surface": "my_tasks",
