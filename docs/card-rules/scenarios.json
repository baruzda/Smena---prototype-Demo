      "expected": {
        "notInSections": [
          "waiting_user"
        ],
        "appliedExceptions": [
          "EXC-SIGNING-001"
        ]
      },
      "executionStatus": "declarative"
    },
    {
      "id": "SCN-CONTENT-001",
