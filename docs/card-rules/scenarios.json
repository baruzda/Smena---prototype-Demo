{
  "version": 1,
  "scenarios": [
    {
      "id": "SCN-CATALOG-001",
      "name": "Доступная услуга проходит фильтры",
      "given": {
        "surface": "tasks",
        "service": {
          "state": "available",
          "matchesFilters": true
        }
      },
      "expected": {
        "template": "service_offer_card",
        "section": "available_offers",
        "appliedRules": [
          "RULE-PLACEMENT-001"
        ]
      },
      "executionStatus": "verified",
      "testEvidence": "tests/service-offer-presentation.test.mjs"
    },
    {
      "id": "SCN-CATALOG-002",
      "name": "Услуга скрыта фильтрами",
      "given": {
        "surface": "tasks",
        "service": {
          "state": "available",
          "matchesFilters": false
        },
        "catalog": {
          "otherOffersExpanded": false
        }
      },
      "expected": {
        "notInSections": [
          "available_offers"
        ],
        "appliedExceptions": [
          "EXC-PLACEMENT-002"
        ]
      },
      "executionStatus": "verified",
      "testEvidence": "tests/service-offer-presentation.test.mjs"
    },
    {
      "id": "SCN-MATCH-001",
      "name": "Услуга полностью совпадает с доступностью",
      "given": {
        "surface": "tasks",
        "service": {
          "state": "available",
          "matchesFilters": true,
          "scheduleCompatible": true,
          "availabilityCompatible": true,
          "overlapsAccepted": false,
          "restrictionTags": [],
          "isSpecialOffer": false
        }
      },
      "expected": {
        "template": "service_offer_card",
        "variant": "default",
        "visibleContent": [
          "marker.suitable_for_you"
        ],
        "appliedRules": [
          "RULE-MARKER-001",
          "RULE-VARIANT-001"
        ]
      },
      "executionStatus": "declarative"
    },
    {
      "id": "SCN-MATCH-002",
      "name": "Время услуги не совпадает с доступностью",
      "given": {
        "surface": "tasks",
        "service": {
          "state": "available",
          "matchesFilters": true,
          "scheduleCompatible": true,
          "availabilityCompatible": false
        }
      },
      "expected": {
        "hiddenContent": [
          "marker.suitable_for_you"
        ],
        "template": "service_offer_card",
        "variant": "default",
        "appliedRules": [
          "RULE-MARKER-001",
          "RULE-VARIANT-001"
        ]
      },
      "executionStatus": "declarative"
    },
    {
      "id": "SCN-SPECIAL-001",
      "name": "Активное специальное предложение без ограничений",
      "given": {
        "surface": "tasks",
        "service": {
          "state": "available",
          "isSpecialOffer": true,
          "specialOfferExpiresAt": "2026-07-23T12:00:00+03:00",
          "restrictionTags": []
        },
        "catalog": {
          "hasAppliedSort": false
        }
      },
      "expected": {
        "variant": "special",
        "section": "special_offers",
        "visibleContent": [
          "marker.specially_for_you",
          "special.countdown",
          "service.primary_action"
        ],
        "appliedRules": [
          "RULE-SPECIAL-001",
          "RULE-SPECIAL-002"
        ]
      },
      "executionStatus": "declarative"
    },
    {
      "id": "SCN-SPECIAL-002",
      "name": "Специальное предложение имеет ограничение",
      "given": {
        "surface": "tasks",
        "service": {
          "state": "available",
          "isSpecialOffer": true,
          "specialOfferExpiresAt": "2026-07-23T12:00:00+03:00",
          "restrictionTags": [
            "не совпадает время"
          ]
        }
      },
      "expected": {
        "notVariant": "special",
        "appliedExceptions": [
          "EXC-SPECIAL-001"
        ]
      },
      "executionStatus": "declarative"
    },
    {
      "id": "SCN-SPECIAL-003",
      "name": "Пользователь выбрал сортировку",
      "given": {
        "surface": "tasks",
        "service": {
          "state": "available",
          "isSpecialOffer": true,
          "restrictionTags": []
        },
        "catalog": {
          "hasAppliedSort": true
        }
      },
      "expected": {
        "order": "according_to_selected_sort",
        "appliedRules": [
          "RULE-SPECIAL-002"
        ]
      },
      "executionStatus": "declarative"
    },
    {
      "id": "SCN-RESTRICTION-001",
      "name": "Одно ограничение",
      "given": {
        "surface": "tasks",
        "service": {
          "state": "available",
          "restrictionTags": [
            "не совпадает время"
          ]
        }
      },
      "expected": {
        "variant": "restriction_status",
        "visibleContent": [
          "restrictions.summary"
        ],
        "appliedRules": [
          "RULE-RESTRICTION-001"
        ]
      },
      "executionStatus": "declarative"
    },
    {
      "id": "SCN-RESTRICTION-002",
      "name": "Два ограничения",
      "given": {
        "surface": "tasks",
        "service": {
          "state": "available",
          "restrictionTags": [
            "не совпадает время",
            "слишком далеко"
          ]
        }
      },
      "expected": {
        "variant": "restriction_status_plus",
        "visibleContent": [
          "restrictions.summary",
          "restrictions.tags"
        ],
        "appliedRules": [
          "RULE-RESTRICTION-002"
        ]
      },
      "executionStatus": "declarative"
    },
    {
      "id": "SCN-RESTRICTION-003",
      "name": "Три ограничения",
      "given": {
        "surface": "tasks",
        "service": {
          "state": "available",
          "restrictionTags": [
            "не совпадает время",
            "слишком далеко",
            "не подходит доступность"
          ]
        }
      },
      "expected": {
        "variant": "restriction_tags",
        "visibleContent": [
          "restrictions.tags"
        ],
        "appliedRules": [
          "RULE-RESTRICTION-003"
        ]
      },
      "executionStatus": "declarative"
    },
    {
      "id": "SCN-RESTRICTION-004",
      "name": "Ограничений нет",
      "given": {
        "surface": "tasks",
        "service": {
          "state": "available",
          "restrictionTags": []
        }
      },
      "expected": {
        "hiddenContent": [
          "restrictions.summary",
          "restrictions.tags"
        ],
        "notVariant": "restriction_tags",
        "appliedRules": [
          "RULE-RESTRICTION-003"
        ]
      },
      "executionStatus": "declarative"
    },
    {
      "id": "SCN-SHIFT-001",
      "name": "Основная смена в текущий день",
      "given": {
        "surface": "tasks",
        "shift": {
          "type": "primary",
          "dateMatchesCurrentDay": true
        }
      },
      "expected": {
        "template": "employee_shift_card",
        "variant": "primary_shift",
        "section": "employee_schedule",
        "order": "before_service_offers_of_day",
        "appliedRules": [
          "RULE-SHIFT-001"
        ]
      },
      "executionStatus": "verified",
      "testEvidence": "tests/service-offer-presentation.test.mjs"
    },
    {
      "id": "SCN-SHIFT-002",
      "name": "Основная смена относится к другому дню",
      "given": {
        "surface": "tasks",
        "shift": {
          "type": "primary",
          "dateMatchesCurrentDay": false
        }
      },
      "expected": {
        "notInSections": [
          "employee_schedule"
        ],
        "appliedRules": [
          "RULE-SHIFT-001"
        ]
      },
      "executionStatus": "verified",
      "testEvidence": "tests/service-offer-presentation.test.mjs"
    },
    {
