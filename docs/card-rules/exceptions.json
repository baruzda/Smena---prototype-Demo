{
  "version": 1,
  "exceptions": [
    {
      "id": "EXC-PLACEMENT-001",
      "name": "Принятая услуга не остаётся среди доступных",
      "status": "active",
      "baseRule": "RULE-PLACEMENT-001",
      "when": { "any": [
        { "path": "service.state", "operator": "in", "value": ["pending_confirmation", "signing_required", "booked", "active", "completed", "cancelled"] }
      ] },
      "override": { "action": "remove_from_surface" },
      "priority": 900,
      "reason": "Пользователь должен видеть дальнейший процесс в Моих заданиях или На подписание, а не в каталоге доступных услуг."
    },
    {
      "id": "EXC-PLACEMENT-002",
      "name": "Скрытая фильтрами услуга не попадает в основную секцию",
      "status": "active",
      "relatedQuestion": "OPEN-QUESTION-014",
      "decision": "DEC-009",
      "baseRule": "RULE-PLACEMENT-001",
      "when": { "all": [
        { "path": "service", "operator": "not_equals", "reference": "catalog.appliedFiltersResult" },
        { "path": "catalog.otherOffersExpanded", "operator": "equals", "value": false }
      ] },
      "override": { "action": "remove_from_surface" },
      "priority": 700,
      "reason": "Фильтры управляют видимостью, но не удаляют услугу из исходного каталога."
    },
    {
      "id": "EXC-MARKER-001",
      "name": "Маркер Подходит вам скрывается у недоступной услуги",
      "status": "active",
      "baseRule": "RULE-MARKER-001",
      "when": { "any": [
        { "path": "service.state", "operator": "in", "value": ["unavailable", "pending_confirmation", "signing_required", "booked", "active", "completed", "cancelled", "expired"] },
        { "path": "service.restrictionTags.length", "operator": "greater_than", "value": 0 }
      ] },
      "override": { "action": "hide" },
      "priority": 900,
      "reason": "Маркер не должен создавать впечатление, что услугу можно принять без ограничений."
    },
    {
      "id": "EXC-SPECIAL-001",
      "name": "Специальное предложение не показывается как special при ограничениях",
      "status": "provisional",
      "relatedQuestion": "OPEN-QUESTION-008",
      "baseRule": "RULE-SPECIAL-001",
      "when": { "any": [
        { "path": "service.restrictionTags.length", "operator": "greater_than", "value": 0 },
        { "path": "service.specialOfferExpiresAt", "operator": "not_exists" },
        { "path": "service.state", "operator": "not_equals", "value": "available" }
      ] },
      "override": { "action": "set_variant", "value": "restriction_status" },
      "priority": 900,
      "reason": "Персональный акцент не должен перекрывать ограничения или недоступность."
    },
    {
      "id": "EXC-FAVORITES-001",
      "name": "Недоступная избранная услуга сохраняется отдельной карточкой",
      "status": "active",
      "baseRule": "RULE-FAVORITES-001",
      "when": { "all": [
        { "path": "service.isFavorite", "operator": "equals", "value": true },
        { "path": "service.state", "operator": "in", "value": ["unavailable", "cancelled", "expired"] }
      ] },
      "override": { "action": "place", "surface": "favorites", "section": "services_unavailable", "variant": "favorite_unavailable" },
      "priority": 800,
      "reason": "Избранное сохраняет пользовательский выбор и объясняет, почему услуга больше недоступна."
    },
    {
      "id": "EXC-SIGNING-001",
      "name": "Документ без действия пользователя не показывается как ожидающий",
      "status": "provisional",
      "relatedQuestion": "OPEN-QUESTION-011",
      "baseRule": "RULE-SIGNING-001",
      "when": { "any": [
        { "path": "signing.actor", "operator": "not_equals", "value": "user" },
        { "path": "signing.status", "operator": "in", "value": ["processing", "signed"] }
      ] },
      "override": { "action": "remove_from_surface", "section": "waiting_user" },
      "priority": 900,
      "reason": "Секция ожидания должна содержать только документы, по которым пользователь может совершить действие."
    }
  ]
}
